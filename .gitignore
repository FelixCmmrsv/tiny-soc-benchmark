# Real credentials -- never commit these.
.secrets/

# Plaintext answer keys -- the private author copy. Only the compiled,
# hashed manifest.yaml (produced by tools/compile_manifest.py) is meant to
# be shared/distributed.
scenarios/*/manifest.source.yaml

# Regenerated by tools/seed_templates.py -- contains account metadata and a
# large marketplace cache, neither belongs in version control.
templates/

# Per-run output (transcripts, scores, logs) -- data, not source.
runs/

# Real Elastic credentials (only .env.example is tracked).
elastic/.env

# Actual scenario telemetry -- not this project's content to redistribute
# (see elastic/README.md). Supply your own per scenario.
elastic/telemetry/data/
elastic/telemetry/data_*/

# Large binary scenario artifacts (disk images, pcaps) referenced by a
# manifest's `artifacts:` list -- same content-provenance reasoning as the
# Elastic telemetry above. Supply your own; see scenario_artifacts/README.md.
scenario_artifacts/*/
!scenario_artifacts/README.md

# Elastic's official agent-skill packs (author: elastic, from the
# elastic/agent-skills repo). A fetched dependency, not our content --
# only the pinned lock file and the README are tracked; the skill payloads
# are populated locally. See elastic_skills/README.md.
elastic_skills/*/
elastic_skills/*
!elastic_skills/README.md
!elastic_skills/skills-lock.json

__pycache__/
*.pyc
