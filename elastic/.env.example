# Copy to .env in this same directory and fill in real values. Never commit
# the real .env (this repo's .gitignore already excludes it).

# Superuser password for the "elastic" account -- pick any strong value,
# this is what docker-compose.yml uses to initialize the cluster.
ELASTIC_PASSWORD=

# Password for the built-in "kibana_system" service account -- Kibana uses
# this to connect to Elasticsearch. Pick any strong value.
KIBANA_SYSTEM_PASSWORD=

# API key import_data.py/index_pattern_manage.py use to authenticate to
# Elasticsearch (sent as `Authorization: ApiKey ...`). Create one AFTER the
# stack is up, from Kibana's Dev Tools or:
#   curl -s -u elastic:$ELASTIC_PASSWORD -X POST http://localhost:9200/_security/api_key \
#     -H 'Content-Type: application/json' \
#     -d '{"name":"harness-full-access","role_descriptors":{"full_access":{"cluster":["all"],"indices":[{"names":["*"],"privileges":["all"]}],"applications":[{"application":"kibana-.kibana","privileges":["*"],"resources":["*"]}]}}}'
# The response's "encoded" field is the value to put here (base64 of id:api_key).
ES_API_KEY=
