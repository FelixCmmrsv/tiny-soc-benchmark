# Copy to .env in this same directory and fill in real values. Never commit
# the real .env (this repo's .gitignore already excludes it). This one file is
# the single source of truth for the Elasticsearch/Kibana connection used by
# both the data loader and the benchmark orchestrator.

# ----------------------------------------------------------------------------
# Where the cluster is
# ----------------------------------------------------------------------------
# Leave these commented to use the bundled local Docker stack (the defaults).
# Set them to point the harness at an existing / remote cluster instead --
# then run with --no-compose so it doesn't try to start the local containers.
# (The orchestrator's --es-url / --kibana-url flags override these per run.)
#ELASTICSEARCH_URL=http://localhost:9200
#KIBANA_URL=http://127.0.0.1:5601

# ----------------------------------------------------------------------------
# Passwords for the bundled local Docker stack (docker-compose.yml)
# ----------------------------------------------------------------------------
# Only needed when running the local stack; pick any strong values. Not used
# when pointing at an external cluster you don't control.
ELASTIC_PASSWORD=
KIBANA_SYSTEM_PASSWORD=

# ----------------------------------------------------------------------------
# How to authenticate to the cluster (pick ONE method)
# ----------------------------------------------------------------------------
# Method A -- API key (recommended). Sent as `Authorization: ApiKey ...`.
# Create one AFTER the cluster is up (from Kibana Dev Tools, or):
#   curl -s -u elastic:$ELASTIC_PASSWORD -X POST $ELASTICSEARCH_URL/_security/api_key \
#     -H 'Content-Type: application/json' \
#     -d '{"name":"harness-full-access","role_descriptors":{"full_access":{"cluster":["all"],"indices":[{"names":["*"],"privileges":["all"]}],"applications":[{"application":"kibana-.kibana","privileges":["*"],"resources":["*"]}]}}}'
# Put the response's "encoded" field (base64 of id:api_key) here:
ES_API_KEY=

# Method B -- HTTP basic auth. Leave ES_API_KEY blank and set these instead.
# ES_USER defaults to "elastic" when ELASTIC_PASSWORD is set, so for the local
# stack you usually don't need these at all. Use them for an external cluster
# with a non-superuser account.
#ES_USER=elastic
#ES_PASSWORD=
